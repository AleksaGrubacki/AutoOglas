@model KorisnikProfilViewModel
@{
    ViewData["Title"] = "Moj profil";
}

@section Styles {
    <style>
        .profil-hero {
            background: #1a1a2e;
            padding: 40px 0;
            margin-bottom: 30px;
        }

        .profil-avatar {
            width: 80px;
            height: 80px;
            background: #e84118;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: white;
            font-weight: 700;
            margin-bottom: 15px;
        }

        .profil-ime {
            color: white;
            font-size: 1.6rem;
            font-weight: 800;
        }

        .profil-email {
            color: rgba(255,255,255,0.6);
        }

        .info-card {
            background: white;
            border-radius: 14px;
            padding: 25px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.07);
            margin-bottom: 20px;
        }

            .info-card h5 {
                font-weight: 700;
                color: #1a1a2e;
                margin-bottom: 20px;
            }

        .oglas-mini {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 12px 0;
            border-bottom: 1px solid #f5f5f5;
        }

            .oglas-mini:last-child {
                border-bottom: none;
            }

        .oglas-mini-img {
            width: 70px;
            height: 52px;
            object-fit: cover;
            border-radius: 8px;
            background: #f0f0f0;
            flex-shrink: 0;
        }

        .oglas-mini-placeholder {
            width: 70px;
            height: 52px;
            background: #f0f0f0;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ccc;
            flex-shrink: 0;
        }

        .oglas-mini-title {
            font-weight: 600;
            font-size: 0.9rem;
            color: #1a1a2e;
        }

        .oglas-mini-price {
            color: #e84118;
            font-weight: 700;
        }

        .oglas-mini-info {
            color: #888;
            font-size: 0.8rem;
        }
    </style>
}

<div class="profil-hero">
    <div class="container">
        <div class="profil-avatar">
            @Model.Ime?[0]@Model.Prezime?[0]
        </div>
        <div class="profil-ime">@Model.Ime @Model.Prezime</div>
        <div class="profil-email">@Model.Email</div>
        <div class="profil-email mt-1" style="font-size:0.85rem;">
            Član od @Model.DatumRegistracije.ToString("MMMM yyyy")
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="row">
        <div class="col-lg-4">
            <div class="info-card">
                <h5><i class="bi bi-person"></i> Informacije</h5>
                <p class="mb-1"><strong>Ime:</strong> @Model.Ime @Model.Prezime</p>
                <p class="mb-1"><strong>Email:</strong> @Model.Email</p>
                <p class="mb-0"><strong>Oglasi:</strong> @(Model.Oglasi?.Count ?? 0)</p>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="info-card">
                <h5><i class="bi bi-list-ul"></i> Moji oglasi (@(Model.Oglasi?.Count ?? 0))</h5>
                @if (Model.Oglasi == null || !Model.Oglasi.Any())
                {
                    <p class="text-muted">Nemate aktivnih oglasa.</p>
                    <a asp-controller="Oglasi" asp-action="Novi"
                       class="btn btn-sm"
                       style="background:#e84118; color:white; border-radius:8px;">
                        Postavi prvi oglas
                    </a>
                }
                else
                {
                    @foreach (var oglas in Model.Oglasi)
                    {
                        var slika = oglas.Slike?.FirstOrDefault(s => s.JeNaslovna);
                        <div class="oglas-mini">
                            @if (slika != null)
                            {
                                <img src="@slika.PutanjaFajla" class="oglas-mini-img" />
                            }
                            else
                            {
                                <div class="oglas-mini-placeholder">
                                    <i class="bi bi-car-front"></i>
                                </div>
                            }
                            <div class="flex-grow-1">
                                <div class="oglas-mini-title">@oglas.Naslov</div>
                                <div class="oglas-mini-info">
                                    @oglas.Model?.Marka?.Naziv @oglas.Model?.Naziv •
                                    @oglas.Godiste. god. •
                                    @oglas.Kilometraza.ToString("N0") km
                                </div>
                            </div>
                            <div class="text-end">
                                <div class="oglas-mini-price">@oglas.Cena.ToString("N0") €</div>
                                <a asp-controller="Oglasi" asp-action="Detalji"
                                   asp-route-id="@oglas.Id"
                                   style="font-size:0.78rem; color:#888;">
                                    Pogledaj →
                                </a>
                                <a asp-controller="Oglasi" asp-action="Uredi"
                                   asp-route-id="@oglas.Id"
                                   class="d-block mt-1"
                                   style="font-size:0.78rem; color:#e84118;">
                                    Izmeni
                                </a>
                                <a asp-controller="Oglasi" asp-action="Obrisi"
                                   asp-route-id="@oglas.Id"
                                   class="d-block mt-1"
                                   style="font-size:0.78rem; color:#c0392b;"
                                   onclick="return confirm('Sigurno želiš da obrišeš ovaj oglas?')">
                                    Obriši
                                </a>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>