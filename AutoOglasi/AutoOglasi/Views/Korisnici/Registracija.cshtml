@{
    ViewData["Title"] = "Registracija";
}

@section Styles {
    <style>
        .auth-wrapper {
            min-height: 80vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f5f6fa;
            padding: 40px 0;
        }

        .auth-card {
            background: white;
            border-radius: 16px;
            padding: 40px;
            width: 100%;
            max-width: 480px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.08);
        }

        .auth-logo {
            text-align: center;
            margin-bottom: 30px;
        }

            .auth-logo span.a {
                color: #1a1a2e;
                font-size: 2rem;
                font-weight: 800;
            }

            .auth-logo span.b {
                color: #e84118;
                font-size: 2rem;
                font-weight: 800;
            }

        .auth-title {
            font-size: 1.4rem;
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: 5px;
        }

        .auth-subtitle {
            color: #888;
            font-size: 0.9rem;
            margin-bottom: 25px;
        }

        .form-label {
            font-weight: 600;
            font-size: 0.88rem;
            color: #555;
        }

        .form-control {
            border-radius: 8px;
            border: 1.5px solid #e0e0e0;
            padding: 11px 14px;
        }

            .form-control:focus {
                border-color: #e84118;
                box-shadow: 0 0 0 3px rgba(232,65,24,0.1);
            }

        .btn-auth {
            background: #e84118;
            color: white;
            border: none;
            border-radius: 10px;
            padding: 13px;
            font-weight: 700;
            font-size: 1rem;
            width: 100%;
            margin-top: 5px;
        }

            .btn-auth:hover {
                background: #c0392b;
            }

        .auth-footer {
            text-align: center;
            margin-top: 20px;
            font-size: 0.9rem;
            color: #888;
        }

            .auth-footer a {
                color: #e84118;
                font-weight: 600;
                text-decoration: none;
            }
    </style>
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-logo">
            <span class="a">Auto</span><span class="b">Oglasi</span>
        </div>
        <div class="auth-title">Kreirajte nalog</div>
        <div class="auth-subtitle">Registrujte se i počnite da prodajete</div>

        @if (ViewBag.Greska != null)
        {
            <div class="alert alert-danger rounded-3 py-2 px-3 mb-3" style="font-size:0.9rem;">
                <i class="bi bi-exclamation-circle"></i> @ViewBag.Greska
            </div>
        }

        <form method="post" asp-action="Registracija">
            @Html.AntiForgeryToken()
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Ime</label>
                    <input type="text" name="ime" class="form-control" placeholder="Marko" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Prezime</label>
                    <input type="text" name="prezime" class="form-control" placeholder="Marković" required />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Email adresa</label>
                <input type="email" name="email" class="form-control" placeholder="vas@email.com" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Lozinka</label>
                <input type="password" name="lozinka" class="form-control" placeholder="••••••••" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Potvrda lozinke</label>
                <input type="password" name="lozinkaPotvrda" class="form-control" placeholder="••••••••" required />
            </div>
            <button type="submit" class="btn-auth">
                <i class="bi bi-person-plus"></i> Registruj se
            </button>
        </form>

        <div class="auth-footer">
            Već imate nalog?
            <a asp-controller="Korisnici" asp-action="Prijava">Prijavite se</a>
        </div>
    </div>
</div>