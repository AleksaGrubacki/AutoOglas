@model IEnumerable<AutoOglasi.Models.Oglas>
@{
    ViewData["Title"] = "Oglasi";
}

@section Styles {
    <style>
        .hero {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            padding: 50px 0 40px;
            margin-bottom: 30px;
        }

            .hero h1 {
                color: white;
                font-weight: 800;
                font-size: 2.2rem;
            }

            .hero p {
                color: rgba(255,255,255,0.7);
            }

        .search-card {
            background: white;
            border-radius: 16px;
            padding: 25px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.15);
        }

            .search-card .form-select,
            .search-card .form-control {
                border-radius: 8px;
                border: 1.5px solid #e0e0e0;
                padding: 10px 14px;
                font-size: 0.9rem;
            }

        .btn-search {
            background: #e84118;
            color: white;
            border: none;
            border-radius: 8px;
            padding: 10px 28px;
            font-weight: 600;
            font-size: 0.95rem;
            width: 100%;
        }

            .btn-search:hover {
                background: #c0392b;
                color: white;
            }

        .oglas-card {
            background: white;
            border-radius: 14px;
            overflow: hidden;
            box-shadow: 0 2px 12px rgba(0,0,0,0.07);
            transition: transform 0.2s, box-shadow 0.2s;
            height: 100%;
        }

            .oglas-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 8px 25px rgba(0,0,0,0.13);
            }

        .oglas-img {
            width: 100%;
            height: 185px;
            object-fit: cover;
            background: #f0f0f0;
        }

        .oglas-img-placeholder {
            width: 100%;
            height: 185px;
            background: linear-gradient(135deg, #f0f0f0, #e0e0e0);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #bbb;
            font-size: 3rem;
        }

        .oglas-body {
            padding: 15px;
        }

        .oglas-title {
            font-weight: 700;
            font-size: 1rem;
            color: #1a1a2e;
            margin-bottom: 4px;
        }

        .oglas-subtitle {
            color: #888;
            font-size: 0.82rem;
            margin-bottom: 10px;
        }

        .oglas-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-bottom: 12px;
        }

        .oglas-tag {
            background: #f5f6fa;
            border-radius: 20px;
            padding: 3px 10px;
            font-size: 0.78rem;
            color: #555;
        }

        .oglas-price {
            font-size: 1.3rem;
            font-weight: 800;
            color: #e84118;
        }

        .oglas-footer {
            padding: 10px 15px;
            border-top: 1px solid #f0f0f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .btn-detalji {
            background: #1a1a2e;
            color: white;
            border-radius: 20px;
            padding: 5px 16px;
            font-size: 0.82rem;
            font-weight: 600;
            text-decoration: none;
        }

            .btn-detalji:hover {
                background: #e84118;
                color: white;
            }

        .results-count {
            color: #888;
            font-size: 0.9rem;
            margin-bottom: 15px;
        }
    </style>
}

<!-- Hero sekcija sa pretragom -->
<div class="hero">
    <div class="container">
        <h1><i class="bi bi-car-front-fill"></i> Pronađi svoje vozilo</h1>
        <p>Pretražuj hiljade oglasa polovnih i novih automobila</p>
        <div class="search-card">
            <form method="get" asp-action="Index">
                <div class="row g-2">
                    <div class="col-md-3">
                        <label class="form-label fw-semibold small">Marka</label>
                        <select name="marka" class="form-select">
                            <option value="">Sve marke</option>
                            @foreach (var m in ViewBag.Marke)
                            {
                                <option value="@m.Value">@m.Text</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold small">Gorivo</label>
                        <select name="gorivo" class="form-select">
                            <option value="">Sve vrste</option>
                            @foreach (var g in ViewBag.Goriva)
                            {
                                <option value="@g">@g</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold small">Cena od (€)</label>
                        <input type="number" name="cenaOd" class="form-control" placeholder="0" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold small">Cena do (€)</label>
                        <input type="number" name="cenaDo" class="form-control" placeholder="100.000" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold small">Godište od</label>
                        <select name="godisteOd" class="form-select">
                            <option value="">Sve godine</option>
                            @foreach (var g in ViewBag.Godine)
                            {
                                <option value="@g">@g</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-1 d-flex align-items-end">
                        <button type="submit" class="btn-search">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="container">
    <p class="results-count">
        <strong>@Model.Count()</strong> oglasa pronađeno
    </p>

    <div class="row">
        @foreach (var oglas in Model)
        {
            var naslovna = oglas.Slike?.FirstOrDefault(s => s.JeNaslovna);
            <div class="col-md-4 col-lg-3 mb-4">
                <div class="oglas-card">
                    @if (naslovna != null)
                    {
                        <img src="@naslovna.PutanjaFajla" class="oglas-img" alt="@oglas.Naslov" />
                    }
                    else
                    {
                        <div class="oglas-img-placeholder">
                            <i class="bi bi-car-front"></i>
                        </div>
                    }
                    <div class="oglas-body">
                        <div class="oglas-title">@oglas.Naslov</div>
                        <div class="oglas-subtitle">
                            @oglas.Model?.Marka?.Naziv @oglas.Model?.Naziv • @oglas.Godiste. god.
                        </div>
                        <div class="oglas-tags">
                            <span class="oglas-tag"><i class="bi bi-fuel-pump"></i> @oglas.Gorivo</span>
                            <span class="oglas-tag"><i class="bi bi-gear"></i> @oglas.Menjac</span>
                            <span class="oglas-tag"><i class="bi bi-speedometer2"></i> @oglas.Kilometraza.ToString("N0") km</span>
                        </div>
                        <div class="oglas-price">@oglas.Cena.ToString("N0") €</div>
                    </div>
                    <div class="oglas-footer">
                        <span style="font-size:0.78rem; color:#aaa;">
                            <i class="bi bi-clock"></i> @oglas.DatumObjave.ToString("dd.MM.yyyy")
                        </span>
                        <a asp-action="Detalji" asp-route-id="@oglas.Id" class="btn-detalji">
                            Pogledaj →
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-search" style="font-size:3rem; color:#ddd;"></i>
            <p class="mt-3 text-muted">Nema oglasa koji odgovaraju pretrazi.</p>
        </div>
    }
</div>