@model IEnumerable<AutoOglasi.Models.Korisnik>
@{
    ViewData["Title"] = "Admin - Korisnici";
}

@section Styles {
    <style>
        .admin-hero {
            background: #1a1a2e;
            padding: 30px 0;
            margin-bottom: 30px;
        }

            .admin-hero h2 {
                color: white;
                font-weight: 800;
            }

            .admin-hero p {
                color: rgba(255,255,255,0.6);
            }

        .table-card {
            background: white;
            border-radius: 14px;
            padding: 25px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        }

        .badge-admin {
            background: #fff3e0;
            color: #e65100;
            border-radius: 20px;
            padding: 3px 10px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .badge-user {
            background: #e3f2fd;
            color: #1565c0;
            border-radius: 20px;
            padding: 3px 10px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .btn-sm-red {
            background: #fce4ec;
            color: #e84118;
            border: none;
            border-radius: 6px;
            padding: 4px 10px;
            font-size: 0.8rem;
            font-weight: 600;
            text-decoration: none;
        }

        .btn-sm-orange {
            background: #fff3e0;
            color: #e65100;
            border: none;
            border-radius: 6px;
            padding: 4px 10px;
            font-size: 0.8rem;
            font-weight: 600;
            text-decoration: none;
        }

        .avatar-sm {
            width: 36px;
            height: 36px;
            background: #e84118;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 0.85rem;
            margin-right: 10px;
        }
    </style>
}

<div class="admin-hero">
    <div class="container">
        <a asp-action="Index" style="color:rgba(255,255,255,0.6); text-decoration:none; font-size:0.9rem;">
            ← Nazad na panel
        </a>
        <h2 class="mt-2"><i class="bi bi-people"></i> Upravljanje korisnicima</h2>
        <p>Ukupno: @Model.Count() korisnika</p>
    </div>
</div>

<div class="container mb-5">
    <div class="table-card">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Korisnik</th>
                        <th>Email</th>
                        <th>Uloga</th>
                        <th>Oglasi</th>
                        <th>Registrovan</th>
                        <th>Akcije</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var k in Model)
                    {
                        <tr>
                            <td>
                                <span class="avatar-sm">
                                    @k.Ime?[0]@k.Prezime?[0]
                                </span>
                                <strong>@k.Ime @k.Prezime</strong>
                            </td>
                            <td class="text-muted">@k.Email</td>
                            <td>
                                @if (k.Uloga == "Admin")
                                {
                                    <span class="badge-admin">👑 Admin</span>
                                }
                                else
                                {
                                    <span class="badge-user">👤 User</span>
                                }
                            </td>
                            <td>@(k.Oglasi?.Count ?? 0)</td>
                            <td class="text-muted small">@k.DatumRegistracije.ToString("dd.MM.yyyy")</td>
                            <td>
                                <a asp-action="PrommeniUlogu" asp-route-id="@k.Id"
                                   class="btn-sm-orange"
                                   onclick="return confirm('Promeniti ulogu ovog korisnika?')">
                                    @(k.Uloga == "Admin" ? "Ukloni admina" : "Postavi admina")
                                </a>
                                @if (k.Id != Context.Session.GetInt32("KorisnikId"))
                                {
                                    <a asp-action="ObrisiKorisnika" asp-route-id="@k.Id"
                                       class="btn-sm-red ms-1"
                                       onclick="return confirm('Sigurno želiš da obrišeš ovog korisnika?')">
                                        Obriši
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>